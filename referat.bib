year = {2021},
keywords = {mixed integer programs, combinatorial optimization, knapsack problem, traveling salesman problem, facility location problem, formulation, extended formulation, convex hull.},
abstract = {Summary After briefly listing some application areas, integer, mixed integer and combinatorial optimization problems are defined. We then show how several well-known problems, such as the knapsack, covering, facility location and traveling salesman problems can be formulated as integer or mixed integer programs. This is followed by a discussion of different formulations, the comparison between formulations, the existence of a “best” formulation, corresponding to the convex hull of the set of feasible solutions, and finally extended formulations that involve additional variables.}
}

